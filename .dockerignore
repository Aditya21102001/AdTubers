# Version control
.git
.gitignore

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local SQLite DB & logs — Render uses PostgreSQL via DATABASE_URL
*.log
**/db.sqlite3
**/db.sqlite3-journal

# Build artifacts (regenerated inside the image)
**/staticfiles/
# NOTE: tubers/media/ holds committed demo images that MUST ship in the image
# (served via urls.py in production), so it is intentionally NOT ignored.
# Runtime uploads to that folder are ephemeral on Render's free tier.

# Environment / secrets
.env
*.env

# IDE / OS cruft
.idea/
.vscode/
.DS_Store
Thumbs.db

# Not needed at runtime
README.md
Pipfile
Pipfile.lock
